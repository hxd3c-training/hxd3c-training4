/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: 'Microsoft YaHei', sans-serif;
}

/* 主色调定义 */
:root {
  --primary-color: #0056b3; /* 科技蓝 */
  --secondary-color: #dc3545; /* 安全红 */
  --light-blue: #e3f2fd;
  --light-red: #f8d7da;
  --dark-blue: #004085;
  --dark-red: #721c24;
}

/* 卡片样式 */
.card {
  background-color: white;
  border-radius: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  padding: 20px;
  margin: 10px;
  transition: all 0.3s ease;
}

.card:hover {
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  transform: translateY(-2px);
}

/* 卡片标题样式 */
.card-title {
  font-size: 18px;
  font-weight: bold;
  margin-bottom: 12px;
  color: var(--primary-color);
}

/* 卡片内容样式 */
.card-content {
  font-size: 14px;
  color: #333;
  line-height: 1.5;
}

/* 红色强调样式 */
.red-accent {
  color: var(--secondary-color);
  font-weight: bold;
}

/* 蓝色强调样式 */
.blue-accent {
  color: var(--primary-color);
  font-weight: bold;
}

/* 布局容器 */
.container {
  padding: 20px;
}

/* 标题样式 */
.main-title {
  font-size: 22px;
  font-weight: bold;
  text-align: center;
  margin-bottom: 10px;
  color: var(--primary-color);
}

.sub-title {
  font-size: 16px;
  text-align: center;
  margin-bottom: 30px;
  color: #666;
}

/* 2x2网格布局 */
.grid-container {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 15px;
}

/* 响应式调整 */
@media (max-width: 768px) {
  .grid-container {
    grid-template-columns: 1fr;
  }
}

/* 按钮样式 */
.btn {
  display: inline-block;
  padding: 8px 16px;
  border-radius: 4px;
  font-size: 14px;
  font-weight: bold;
  text-align: center;
  margin-top: 10px;
}

.btn-primary {
  background-color: var(--primary-color);
  color: white;
}

.btn-secondary {
  background-color: var(--secondary-color);
  color: white;
}

/* 分割线 */
.divider {
  height: 1px;
  background-color: #e0e0e0;
  margin: 15px 0;
}

/* 图标样式 */
.icon {
  width: 40px;
  height: 40px;
  margin-bottom: 10px;
}